<h1 class="mb-4">Notice Board</h1>
<div class="mb-4">

  <%= form_with url: notices_path,
  method: :get,
  local: true do %>

    <div class="row">

      <div class="col-md-4">

        <%= select_tag :category,

        options_for_select(
          ['General', 'Event', 'Job', 'Other'],
          params[:category]
        ),

        include_blank: "All Categories",

        class: "form-select" %>

      </div>

      <div class="col-md-2">

        <%= submit_tag "Filter",
        class: "btn btn-primary" %>

      </div>

    </div>

  <% end %>

</div>

<%= link_to "New Notice",
new_notice_path,
class: "btn btn-primary mb-4" %>

<div class="row">

  <% @notices.each do |notice| %>

    <div class="col-md-12 mb-4">

      <div class="card shadow-sm">

        <div class="card-body">

          <% if notice.pinned %>
            <span class="badge bg-danger">
              Pinned
            </span>
          <% end %>

          <span class="badge bg-secondary">
            <%= notice.category %>
          </span>

          <h4 class="mt-2">
            <%= notice.title %>
          </h4>

          <p>
            <%= truncate(notice.body, length: 120) %>
          </p>

          <small class="text-muted">
            By <%= notice.author_name %>
          </small>

          <br><br>

          <%= link_to "View",
          notice,
          class: "btn btn-sm btn-outline-primary" %>

          <%= button_to "Delete",
          notice,
          method: :delete,
          class: "btn btn-sm btn-outline-danger",
          form: { style: 'display:inline;' } %>

        </div>

      </div>

    </div>

  <% end %>

</div>